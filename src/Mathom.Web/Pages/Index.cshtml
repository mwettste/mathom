@page
@model IndexModel
@{ ViewData["Title"] = "Timeline"; }

<div class="toolbar">
    <input class="search" type="search" name="q" placeholder="Search your brain…" autocomplete="off"
           aria-label="Search notes"
           hx-get="/?handler=Search" hx-trigger="input changed delay:300ms, search"
           hx-target="#item-list" hx-swap="innerHTML" />
</div>

<div id="item-list">
    <partial name="Shared/_ItemList" model="Model.Items" />
</div>
