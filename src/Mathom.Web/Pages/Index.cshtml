@page
@model IndexModel
@{ ViewData["Title"] = "Timeline"; }

<p class="text-xs text-base-content/60 mb-2">Context: <span class="font-medium">@Model.CurrentContextName</span></p>

<div class="mb-4 relative">
    <input class="input w-full pr-10" type="search" name="q" value="@Model.Q"
           placeholder="Search your brain…" autocomplete="off" aria-label="Search notes"
           hx-get="/" hx-target="#results" hx-select="#results" hx-push-url="true"
           hx-trigger="input changed delay:300ms, search"
           hx-include="#active-filters [name]" hx-indicator="#search-spin" />
    <span id="search-spin" class="htmx-indicator loading loading-spinner loading-sm absolute right-3 top-1/2 -translate-y-1/2"></span>
    <span id="active-filters" hidden>
        @if (Model.Tag is not null) { <input type="hidden" name="tag" value="@Model.Tag" /> }
        @if (Model.Type is not null) { <input type="hidden" name="type" value="@Model.TypeParam" /> }
        @if (Model.Actionable is not null) { <input type="hidden" name="actionable" value="@Model.ActionableParam" /> }
    </span>
</div>

<div id="results">
    @if (Model.HasFilters)
    {
        <div class="mb-3 flex flex-wrap items-center gap-2 text-sm">
            <span class="font-mono text-xs uppercase tracking-wider text-base-content/50">Filters:</span>
            @if (Model.Tag is not null)
            {
                <a class="badge badge-outline gap-1 font-mono" href="@Model.WithoutTag()">#@Model.Tag <span aria-hidden="true">✕</span></a>
            }
            @if (Model.Type is not null)
            {
                <a class="badge badge-outline gap-1 font-mono" href="@Model.WithoutType()">type:@Model.TypeParam <span aria-hidden="true">✕</span></a>
            }
            @if (Model.Actionable == true)
            {
                <a class="badge badge-outline gap-1 font-mono" href="@Model.WithoutActionable()">actionable <span aria-hidden="true">✕</span></a>
            }
            <a class="ml-auto link link-hover text-xs text-base-content/50" href="/">Clear</a>
        </div>
    }
    <div class="mb-5 flex flex-wrap gap-1.5">
        @foreach (var tt in IndexModel.AllTypes)
        {
            var active = Model.Type == tt;
            <a class="btn btn-xs font-mono @(active ? "btn-primary" : "btn-outline")" href="@Model.ToggleType(tt)">@tt.ToString().ToLowerInvariant()</a>
        }
        <a class="btn btn-xs font-mono @(Model.Actionable == true ? "btn-primary" : "btn-outline")" href="@Model.ToggleActionable()">actionable</a>
    </div>

    @if (Model.Items.Count == 0 && (Model.HasFilters || Model.Q is not null))
    {
        <p class="py-16 text-center text-base-content/60">No notes match these filters — try broadening your search. <a class="link link-primary" href="/">Clear</a></p>
    }
    else
    {
        <div id="item-list">
            <partial name="Shared/_ItemList" model="Model.Items" />
        </div>
    }
</div>
