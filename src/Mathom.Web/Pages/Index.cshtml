@page
@model IndexModel
@{ ViewData["Title"] = "Timeline"; }

<div class="toolbar">
    <input class="search" type="search" name="q" value="@Model.Q"
           placeholder="Search your brain…" autocomplete="off" aria-label="Search notes"
           hx-get="/" hx-target="#results" hx-select="#results" hx-push-url="true"
           hx-trigger="input changed delay:300ms, search"
           hx-include="#active-filters [name]" />
    <span id="active-filters" hidden>
        @if (Model.Tag is not null) { <input type="hidden" name="tag" value="@Model.Tag" /> }
        @if (Model.Type is not null) { <input type="hidden" name="type" value="@Model.TypeParam" /> }
        @if (Model.Actionable is not null) { <input type="hidden" name="actionable" value="@Model.ActionableParam" /> }
    </span>
</div>

<div id="results">
    @if (Model.HasFilters)
    {
        <div class="filters">
            <span class="filters__label">Filters:</span>
            @if (Model.Tag is not null)
            {
                <a class="chip" href="@Model.WithoutTag()">#@Model.Tag <span aria-hidden="true">✕</span></a>
            }
            @if (Model.Type is not null)
            {
                <a class="chip" href="@Model.WithoutType()">type:@Model.TypeParam <span aria-hidden="true">✕</span></a>
            }
            @if (Model.Actionable == true)
            {
                <a class="chip" href="@Model.WithoutActionable()">actionable <span aria-hidden="true">✕</span></a>
            }
            <a class="filters__clear" href="/">Clear</a>
        </div>
    }
    <div class="quickfilters">
        @foreach (var tt in IndexModel.AllTypes)
        {
            var active = Model.Type == tt;
            <a class="quickfilter @(active ? "is-active" : "")" href="@Model.ToggleType(tt)">@tt.ToString().ToLowerInvariant()</a>
        }
        <a class="quickfilter @(Model.Actionable == true ? "is-active" : "")" href="@Model.ToggleActionable()">actionable</a>
    </div>

    @if (Model.Items.Count == 0 && (Model.HasFilters || Model.Q is not null))
    {
        <p class="empty">No notes match these filters — try broadening your search. <a href="/">Clear</a></p>
    }
    else
    {
        <div id="item-list">
            <partial name="Shared/_ItemList" model="Model.Items" />
        </div>
    }
</div>
