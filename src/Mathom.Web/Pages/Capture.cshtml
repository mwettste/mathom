@page
@model CaptureModel
@{ ViewData["Title"] = "Capture"; }

<section class="capture">
    <div class="card" x-data="textCapture()">
        <h2 class="card__title">Type</h2>
        <textarea class="field" x-model="text" rows="4" placeholder="Dump an idea…"
                  @@keydown.cmd.enter="submit()" @@keydown.ctrl.enter="submit()"></textarea>
        <div class="card__actions">
            <button class="btn btn--primary" type="button" @@click="submit()"
                    x-bind:disabled="busy" x-text="busy ? 'Saving…' : 'Capture'"></button>
            <span class="hint" x-text="status"></span>
        </div>
    </div>

    <div class="card" x-data="voiceCapture()">
        <h2 class="card__title">Speak</h2>
        <button class="btn btn--record" type="button" @@click="toggle()"
                x-bind:class="{ 'is-recording': recording }" x-bind:disabled="uploading">
            <span class="rec-dot" x-show="recording"></span>
            <span x-text="recording ? ('Stop · ' + fmt(elapsed)) : (uploading ? 'Uploading…' : 'Record')"></span>
        </button>
        <p class="hint" x-text="status"></p>
        <div class="hint capture__done" x-show="done" x-cloak>
            <span class="pill processing"><span class="dot"></span>transcribing in the background</span>
            <a href="/">View timeline →</a>
        </div>
    </div>
</section>
