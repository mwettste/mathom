@page "/Register"
@model Mathom.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}
<section class="flex min-h-[70vh] items-center justify-center px-4">
    <div class="card bg-base-200 w-full max-w-sm">
        <div class="card-body">
            <h1 class="font-display text-2xl font-medium leading-snug mb-2">Create your account</h1>
            <form method="post" class="flex flex-col gap-3">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-error text-sm"></div>
                }
                <div>
                    <label asp-for="Input.Email" class="font-mono text-xs uppercase tracking-wider text-base-content/50">Email</label>
                    <input class="input w-full" asp-for="Input.Email" autocomplete="username" autofocus />
                </div>
                <div>
                    <label asp-for="Input.Password" class="font-mono text-xs uppercase tracking-wider text-base-content/50">Password</label>
                    <input class="input w-full" asp-for="Input.Password" type="password" autocomplete="new-password" />
                </div>
                <button type="submit" class="btn btn-primary w-full mt-2">Create account</button>
            </form>
            <p class="text-xs text-base-content/50 mt-4">Already have an account? <a href="/Login" class="link link-primary">Sign in →</a></p>
        </div>
    </div>
</section>
