@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Account") · Mathom</title>
    <link rel="stylesheet" href="~/css/mathom.css" asp-append-version="true" />
    <script>
        (function () {
            var root = document.documentElement;
            var saved = localStorage.getItem('mathom-theme');
            root.setAttribute('data-theme', saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'));
        })();
    </script>
</head>
<body class="auth-body">
    <main class="auth-card">
        <a class="brand" href="/">Mathom</a>
        @RenderBody()
    </main>
</body>
</html>
