@page "/Pending"
@model PendingModel
@{ ViewData["Title"] = "Pending approval"; }

<h1 class="note__title">Awaiting approval</h1>
<p class="hint">Your account has been created and is waiting for an administrator to approve access. Please check back later.</p>
<form method="post" action="/Logout">
    @Html.AntiForgeryToken()
    <button class="btn" type="submit">Log out</button>
</form>
