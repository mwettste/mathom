@page "/Pending"
@model PendingModel
@{ ViewData["Title"] = "Pending approval"; ViewData["HideAppNav"] = true; }

<section class="auth">
    <div class="card">
        <h1 class="note__title">Awaiting approval</h1>
        <p class="hint">Your account is ready — an administrator just needs to grant access. Check back soon.</p>
        <form method="post" action="/Logout">
            @Html.AntiForgeryToken()
            <button class="btn" type="submit">Sign out</button>
        </form>
    </div>
</section>
