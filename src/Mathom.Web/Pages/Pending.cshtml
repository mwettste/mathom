@page "/Pending"
@model PendingModel
@{ ViewData["Title"] = "Pending approval"; ViewData["HideAppNav"] = true; }

<section class="flex min-h-[70vh] items-center justify-center px-4">
    <div class="card bg-base-200 w-full max-w-sm">
        <div class="card-body">
            <h1 class="font-display text-2xl font-medium leading-snug mb-2">Awaiting approval</h1>
            <p class="text-sm text-base-content/70 mb-4">Your account is ready — an administrator just needs to grant access. Check back soon.</p>
            <form method="post" action="/Logout">
                @Html.AntiForgeryToken()
                <button class="btn btn-primary w-full" type="submit">Sign out</button>
            </form>
        </div>
    </div>
</section>
