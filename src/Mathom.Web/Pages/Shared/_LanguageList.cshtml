@using Mathom.Web.Languages
@model IReadOnlyList<UserLanguageView>

@if (Model.Count == 0)
{
    <p class="text-sm text-base-content/60">No languages yet. Add one below to start working multilingually.</p>
}
else
{
    <ul class="divide-y divide-base-300">
        @foreach (var lang in Model)
        {
            <li class="flex items-center justify-between gap-3 py-3">
                <span class="font-medium">
                    @lang.DisplayName
                    @if (lang.IsPrimary)
                    {
                        <span class="badge badge-primary badge-sm ml-2">primary</span>
                    }
                </span>
                <span class="flex gap-2">
                    @if (!lang.IsPrimary)
                    {
                        <form method="post" hx-post="/Settings?handler=SetPrimary" hx-target="#language-list" hx-swap="innerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="locale" value="@lang.Locale" />
                            <button class="btn btn-ghost btn-xs" type="submit">Make primary</button>
                        </form>
                        <form method="post" hx-post="/Settings?handler=Remove" hx-target="#language-list" hx-swap="innerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="locale" value="@lang.Locale" />
                            <button class="btn btn-ghost btn-xs text-error" type="submit">Remove</button>
                        </form>
                    }
                </span>
            </li>
        }
    </ul>
}
