@using System.Security.Claims
@inject Mathom.Web.Contexts.ContextService Contexts
@{
    // One-click context switcher: a horizontal, scrollable row of pills below the
    // header. Each pill POSTs SetCurrent (HX-Redirect to / reloads the shell).
    var uid = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var ctxItems = uid is null ? new List<Mathom.Web.Contexts.ContextView>() : await Contexts.ListAsync(uid, default);
    var currentId = uid is null ? (Guid?)null : await Contexts.GetCurrentAsync(uid, default);
    string Pill(bool active) => active
        ? "btn btn-sm btn-primary rounded-full"
        : "btn btn-sm btn-ghost rounded-full border border-base-300";
}
<nav aria-label="Switch context"
     class="bg-base-100 border-b border-base-300 px-4 py-2 flex items-center gap-2 overflow-x-auto whitespace-nowrap [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
    <form method="post" action="/Contexts?handler=SetCurrent" hx-post="/Contexts?handler=SetCurrent" class="shrink-0">
        @Html.AntiForgeryToken()
        <button type="submit" class="@Pill(currentId is null)">Inbox</button>
    </form>
    @foreach (var c in ctxItems)
    {
        <form method="post" action="/Contexts?handler=SetCurrent" hx-post="/Contexts?handler=SetCurrent" class="shrink-0">
            @Html.AntiForgeryToken()
            <input type="hidden" name="contextId" value="@c.Id" />
            <button type="submit" class="@Pill(currentId == c.Id)">@c.Name</button>
        </form>
    }
    <a href="/Contexts" aria-label="Manage contexts" class="btn btn-sm btn-ghost btn-circle shrink-0 ml-auto">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
    </a>
</nav>
