@model Mathom.Web.Glossary.GlossaryDescription

<form method="post" class="glossary-desc__form"
      hx-post="@($"/Glossary?handler=SetDescription&id={Model.Id}")"
      hx-target="#glossary-desc-@Model.Id" hx-swap="innerHTML">
    @Html.AntiForgeryToken()
    <textarea class="field glossary-desc__input" name="description" rows="2" maxlength="500"
              placeholder="What is this term? (domain context for the AI)">@Model.Description</textarea>
    <div class="glossary-desc__actions">
        <button class="btn btn--primary" type="submit">Save</button>
        <button class="linklike" type="button"
                hx-get="@($"/Glossary?handler=ShowDescription&id={Model.Id}")"
                hx-target="#glossary-desc-@Model.Id" hx-swap="innerHTML">Cancel</button>
    </div>
</form>
