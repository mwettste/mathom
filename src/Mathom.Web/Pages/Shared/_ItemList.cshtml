@using Mathom.Web.Domain
@model IReadOnlyList<Mathom.Web.Search.ItemSummary>

@if (Model.Count == 0)
{
    <p class="py-16 text-center text-base-content/60">Nothing here yet. <a class="link link-primary" href="/Capture">Capture your first thought →</a></p>
}
else
{
    <ul class="divide-y divide-base-300">
        @foreach (var item in Model)
        {
            var inflight = StatusView.InFlight(item.Status);
            var (pillCss, pillLabel) = StatusView.Pill(item.Status, item.SourceType);
            var title = item.Title
                ?? (item.SourceType == SourceType.Voice ? "Voice note" : "Quick note");
            <li class="py-4">
                <div class="flex items-baseline justify-between gap-3">
                    <a class="font-display text-base font-medium leading-snug hover:text-primary transition-colors @(inflight ? "text-base-content/60" : "")" href="/Note/@item.Id">@title</a>
                    <span class="shrink-0 font-mono text-xs text-base-content/40">@RelativeTime.Ago(item.CreatedAt)</span>
                </div>
                @if (!string.IsNullOrEmpty(item.CleanText))
                {
                    <p class="mt-1 text-sm leading-relaxed text-base-content/70 line-clamp-3">@item.CleanText</p>
                }
                <div class="mt-2 flex flex-wrap items-center gap-2">
                    @if (!string.IsNullOrEmpty(pillLabel))
                    {
                        <span class="badge badge-sm @(pillCss == "failed" ? "badge-error" : "badge-info")">@pillLabel</span>
                    }
                    else if (item.ItemType is not null)
                    {
                        <span class="font-mono text-xs uppercase tracking-wider text-base-content/40">@item.ItemType.ToString()!.ToLowerInvariant()</span>
                    }
                    @if (item.Actionable)
                    {
                        <span class="badge badge-warning badge-sm">actionable</span>
                    }
                    @foreach (var tag in item.Tags)
                    {
                        <a class="badge badge-ghost badge-sm font-mono" href="/?tag=@Uri.EscapeDataString(tag)">#@tag</a>
                    }
                </div>
            </li>
        }
    </ul>

    @if (Model.Any(i => StatusView.InFlight(i.Status)))
    {
        <div aria-hidden="true"
             hx-get="/?handler=Timeline" hx-trigger="every 3s"
             hx-target="#item-list" hx-ext="morph" hx-swap="morph:innerHTML"></div>
    }
}
