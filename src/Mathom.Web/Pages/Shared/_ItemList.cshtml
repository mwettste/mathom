@using Mathom.Web.Domain
@model IReadOnlyList<Mathom.Web.Search.ItemSummary>

@if (Model.Count == 0)
{
    <p class="empty">Nothing here yet. <a href="/Capture">Capture your first thought →</a></p>
}
else
{
    <ul class="entries">
        @foreach (var item in Model)
        {
            var inflight = StatusView.InFlight(item.Status);
            var (pillCss, pillLabel) = StatusView.Pill(item.Status, item.SourceType);
            var title = item.Title
                ?? (item.SourceType == SourceType.Voice ? "Voice note" : "Quick note");
            <li class="entry @(inflight ? "entry--inflight" : "")">
                <div class="accession">
                    <span class="callno">@CallNumber.For(item.Id)</span>
                    @if (!string.IsNullOrEmpty(pillLabel))
                    {
                        <span class="stamp stamp--@pillCss">@pillLabel</span>
                    }
                    else if (item.ItemType is not null)
                    {
                        <span class="kind">@item.ItemType.ToString()!.ToLowerInvariant()</span>
                    }
                </div>
                <div class="entry__head">
                    <a class="entry__title" href="/Note/@item.Id">@title</a>
                    <span class="entry__time">@RelativeTime.Ago(item.CreatedAt)</span>
                </div>
                @if (!string.IsNullOrEmpty(item.CleanText))
                {
                    <p class="entry__body">@item.CleanText</p>
                }
                <div class="entry__meta">
                    @if (item.Actionable)
                    {
                        <span class="flag">actionable</span>
                    }
                    @foreach (var tag in item.Tags)
                    {
                        <a class="tag" href="/?tag=@Uri.EscapeDataString(tag)">#@tag</a>
                    }
                </div>
            </li>
        }
    </ul>

    @if (Model.Any(i => StatusView.InFlight(i.Status)))
    {
        <div class="poller" aria-hidden="true"
             hx-get="/?handler=Timeline" hx-trigger="every 3s"
             hx-target="#item-list" hx-ext="morph" hx-swap="morph:innerHTML"></div>
    }
}
