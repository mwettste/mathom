@using System.Security.Claims
@inject Mathom.Web.Contexts.ContextService Contexts
@{
    // Renders the <li> form items that POST SetCurrent. Shared by the desktop
    // switcher dropdown and the mobile hamburger menu so both stay in sync.
    var uid = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var ctxItems = uid is null ? new List<Mathom.Web.Contexts.ContextView>() : await Contexts.ListAsync(uid, default);
    var currentId = uid is null ? (Guid?)null : await Contexts.GetCurrentAsync(uid, default);
}
<li>
    <form method="post" action="/Contexts?handler=SetCurrent" hx-post="/Contexts?handler=SetCurrent">
        @Html.AntiForgeryToken()
        <button type="submit" class="@(currentId is null ? "menu-active w-full text-left" : "w-full text-left")">Inbox</button>
    </form>
</li>
@foreach (var c in ctxItems)
{
    <li>
        <form method="post" action="/Contexts?handler=SetCurrent" hx-post="/Contexts?handler=SetCurrent">
            @Html.AntiForgeryToken()
            <input type="hidden" name="contextId" value="@c.Id" />
            <button type="submit" class="@(currentId == c.Id ? "menu-active w-full text-left" : "w-full text-left")">@c.Name</button>
        </form>
    </li>
}
