@using Mathom.Web.Domain
@model IReadOnlyList<Mathom.Web.Search.ItemSummary>

@if (Model.Count == 0)
{
    <p class="py-16 text-center text-base-content/60">Nothing in the bin — the archive is clean.</p>
}
else
{
    <ul class="divide-y divide-base-300">
        @foreach (var item in Model)
        {
            var title = item.Title ?? (item.SourceType == SourceType.Voice ? "Voice note" : "Quick note");
            <li class="py-4">
                <div>
                    <span class="font-display text-base font-medium text-base-content/50">@title</span>
                </div>
                @if (!string.IsNullOrEmpty(item.CleanText))
                {
                    <p class="text-sm text-base-content/40 line-clamp-2">@item.CleanText</p>
                }
                <div class="mt-2 flex flex-wrap items-center gap-3">
                    <form method="post" hx-post="@($"/Trash?handler=Restore&id={item.Id}")"
                          hx-target="#trash-list" hx-swap="innerHTML">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-ghost btn-sm" type="submit">Restore</button>
                    </form>
                    <form method="post" hx-post="@($"/Trash?handler=Purge&id={item.Id}")"
                          hx-target="#trash-list" hx-swap="innerHTML" hx-confirm="Permanently delete this note? This cannot be undone.">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-ghost btn-sm text-error" type="submit">Delete permanently</button>
                    </form>
                </div>
            </li>
        }
    </ul>
}
