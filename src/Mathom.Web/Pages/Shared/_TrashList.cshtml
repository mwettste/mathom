@using Mathom.Web.Domain
@using Mathom.Web.Pages
@model IReadOnlyList<Mathom.Web.Search.ItemSummary>

@if (Model.Count == 0)
{
    <p class="empty">Nothing in the bin — the archive is clean.</p>
}
else
{
    <ul class="entries">
        @foreach (var item in Model)
        {
            var title = item.Title ?? (item.SourceType == SourceType.Voice ? "Voice note" : "Quick note");
            <li class="entry entry--trashed">
                <div class="accession">
                    <span class="callno">@CallNumber.For(item.Id)</span>
                </div>
                <div class="entry__head">
                    <span class="entry__title">@title</span>
                </div>
                @if (!string.IsNullOrEmpty(item.CleanText))
                {
                    <p class="entry__body">@item.CleanText</p>
                }
                <div class="entry__meta trash-actions">
                    <form method="post" hx-post="@($"/Trash?handler=Restore&id={item.Id}")"
                          hx-target="#trash-list" hx-swap="innerHTML">
                        @Html.AntiForgeryToken()
                        <button class="linklike" type="submit">Restore</button>
                    </form>
                    <form method="post" hx-post="@($"/Trash?handler=Purge&id={item.Id}")"
                          hx-target="#trash-list" hx-swap="innerHTML" hx-confirm="Permanently delete this note? This cannot be undone.">
                        @Html.AntiForgeryToken()
                        <button class="linklike linklike--danger" type="submit">Delete permanently</button>
                    </form>
                </div>
            </li>
        }
    </ul>
}
