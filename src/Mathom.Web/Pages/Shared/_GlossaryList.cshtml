@model IReadOnlyList<Mathom.Web.Glossary.GlossaryTermView>

@if (Model.Count == 0)
{
    <p class="empty">No terms yet.</p>
}
else
{
    <ul class="glossary-terms">
        @foreach (var t in Model)
        {
            <li class="glossary-term">
                <div class="glossary-term__head">
                    <span>@t.Term</span>
                    <form method="post" hx-post="@($"/Glossary?handler=Remove&id={t.Id}")"
                          hx-target="#glossary-list" hx-swap="innerHTML">
                        @Html.AntiForgeryToken()
                        <button class="linklike linklike--danger" type="submit" aria-label="Remove @t.Term">✕</button>
                    </form>
                </div>
                @if (t.Variants.Count > 0)
                {
                    <div class="glossary-variants">
                        @foreach (var v in t.Variants)
                        {
                            <div class="chip">
                                <span>@v.Text</span>
                                <form method="post" hx-post="@($"/Glossary?handler=RemoveVariant&id={v.Id}")"
                                      hx-target="#glossary-list" hx-swap="innerHTML" class="glossary-variant__remove">
                                    @Html.AntiForgeryToken()
                                    <button class="linklike" type="submit" aria-label="Remove variant @v.Text">✕</button>
                                </form>
                            </div>
                        }
                    </div>
                }
            </li>
        }
    </ul>
}
