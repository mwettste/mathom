@model IReadOnlyList<(System.Guid Id, string Term)>

@if (Model.Count == 0)
{
    <p class="empty">No terms yet.</p>
}
else
{
    <ul class="glossary-terms">
        @foreach (var t in Model)
        {
            <li class="glossary-term">
                <span>@t.Term</span>
                <form method="post" hx-post="@($"/Glossary?handler=Remove&id={t.Id}")"
                      hx-target="#glossary-list" hx-swap="innerHTML">
                    @Html.AntiForgeryToken()
                    <button class="linklike linklike--danger" type="submit" aria-label="Remove @t.Term">✕</button>
                </form>
            </li>
        }
    </ul>
}
