@using Mathom.Web.Domain
@model Mathom.Web.Search.ItemDetail
@{
    var (pillCss, pillLabel) = StatusView.Pill(Model.Status, Model.SourceType);
    var inflight = StatusView.InFlight(Model.Status);
    var title = Model.Title ?? (Model.SourceType switch {
        SourceType.Voice => "Voice note",
        SourceType.Photo => "Photo note",
        _ => "Quick note"
    });
}
<header class="mb-4">
    <div class="flex items-center gap-2 mb-1">
        @if (!string.IsNullOrEmpty(pillLabel))
        {
            <span class="badge badge-sm @(Model.Status == ItemStatus.Failed ? "badge-error" : "badge-info")">@pillLabel</span>
        }
        else
        {
            @if (Model.ItemType is not null)
            {
                <span class="font-mono text-xs text-base-content/40">@Model.ItemType.ToString()!.ToLowerInvariant()</span>
            }
        }
        @if (Model.Actionable)
        {
            <span class="font-mono text-xs text-base-content/40">actionable</span>
        }
        <span class="font-mono text-xs text-base-content/40 ml-auto">@RelativeTime.Ago(Model.CreatedAt)</span>
    </div>
    <h1 class="font-display text-2xl font-medium leading-snug">@title</h1>
</header>

@if (Model.Status == ItemStatus.Ready || Model.Status == ItemStatus.Failed)
{
    <div class="flex gap-2 mb-4">
        @if (Model.Status == ItemStatus.Ready)
        {
            <button class="btn btn-ghost btn-sm" type="button"
                    hx-get="@($"/Note/{Model.Id}?handler=Edit")" hx-target="#note-content" hx-swap="innerHTML"><span class="htmx-indicator loading loading-spinner loading-xs"></span>Edit</button>
        }
        <form method="post"
              hx-post="@($"/Note/{Model.Id}?handler=Reprocess")" hx-target="#note-content" hx-swap="innerHTML"
              hx-on::after-request="if (event.detail.successful) window.toast &amp;&amp; toast('Re-processing…', 'info')">
            @Html.AntiForgeryToken()
            <button class="btn btn-ghost btn-sm" type="submit"><span class="htmx-indicator loading loading-spinner loading-xs"></span>Re-process</button>
        </form>
        @if (Model.Status == ItemStatus.Ready)
        {
            <form method="post"
                  hx-post="@($"/Note/{Model.Id}?handler=Delete")" hx-confirm="Move this note to trash?">
                @Html.AntiForgeryToken()
                <button class="btn btn-ghost btn-sm text-error" type="submit">Delete</button>
            </form>
        }
    </div>
}

@if (Model.Status == ItemStatus.Failed)
{
    <div class="alert alert-error mb-4">Couldn't process this note. <span>@Model.Error</span></div>
}

@if (!string.IsNullOrEmpty(Model.CleanText))
{
    <div class="text-base leading-relaxed whitespace-pre-wrap max-w-prose mb-4" data-glossary-source>@Model.CleanText</div>
}
else if (inflight)
{
    <p class="text-base-content/50 mb-4">Working on it…</p>
}

@if (Model.SourceType == SourceType.Voice && !string.IsNullOrEmpty(Model.RawText) && Model.RawText != Model.CleanText)
{
    <section class="mb-4">
        <h2 class="font-display text-base font-medium text-base-content/70 mb-1">Transcript</h2>
        <p class="text-base leading-relaxed whitespace-pre-wrap max-w-prose text-base-content/50" data-glossary-source>@Model.RawText</p>
    </section>
}

@if (Model.PhotoExternalIds.Count > 0)
{
    <section class="mb-4 grid grid-cols-2 gap-2 sm:grid-cols-3" x-data="{ zoom: null }">
        @foreach (var pid in Model.PhotoExternalIds)
        {
            <img class="h-32 w-full rounded-box border border-base-300 object-cover cursor-zoom-in"
                 src="@($"/media/{pid}?variant=display")" alt="Captured photo" loading="lazy"
                 x-on:click="zoom = $el.currentSrc || $el.src" />
        }
        <div x-show="zoom" x-cloak
             x-on:click="zoom = null" x-on:keydown.escape.window="zoom = null"
             class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4 cursor-zoom-out">
            <img x-bind:src="zoom" alt="Captured photo, enlarged" class="max-h-full max-w-full rounded-box" />
        </div>
    </section>
}

@if (Model.Tags.Count > 0)
{
    <div class="flex flex-wrap gap-1 mb-4">
        @foreach (var t in Model.Tags)
        {
            <a class="badge badge-ghost badge-sm font-mono" href="/?tag=@Uri.EscapeDataString(t)">#@t</a>
        }
    </div>
}

@if (inflight)
{
    <div aria-hidden="true"
         hx-get="@($"/Note/{Model.Id}?handler=Content")" hx-trigger="every 3s"
         hx-target="#note-content" hx-ext="morph" hx-swap="morph:innerHTML"></div>
}
