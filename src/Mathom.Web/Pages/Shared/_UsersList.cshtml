@using System.Security.Claims
@model IReadOnlyList<Mathom.Web.Admin.UserRow>
@{ var me = User.FindFirstValue(ClaimTypes.NameIdentifier); }

<ul class="divide-y divide-base-300">
    @foreach (var u in Model)
    {
        <li class="flex items-center justify-between gap-3 py-4">
            <div class="flex items-center gap-2">
                <span class="font-sans text-sm">@u.Email</span>
                @if (!u.IsApproved)
                {
                    <span class="badge badge-info badge-sm">pending</span>
                }
            </div>
            <div>
                @if (!u.IsApproved)
                {
                    <form method="post" hx-post="@($"/Admin/Users?handler=Approve&id={u.Id}")"
                          hx-target="#users-list" hx-swap="innerHTML">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-primary btn-sm" type="submit">Approve</button>
                    </form>
                }
                else if (u.Id != me)
                {
                    <form method="post" hx-post="@($"/Admin/Users?handler=Revoke&id={u.Id}")"
                          hx-target="#users-list" hx-swap="innerHTML">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-ghost btn-sm text-error" type="submit">Revoke</button>
                    </form>
                }
            </div>
        </li>
    }
</ul>
