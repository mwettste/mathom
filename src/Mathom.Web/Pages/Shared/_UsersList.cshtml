@using System.Security.Claims
@model IReadOnlyList<Mathom.Web.Admin.UserRow>
@{ var me = User.FindFirstValue(ClaimTypes.NameIdentifier); }

<ul class="glossary-terms">
    @foreach (var u in Model)
    {
        <li class="glossary-term">
            <div class="glossary-term__head">
                <span>@u.Email @(u.IsApproved ? "" : "· pending")</span>
                @if (!u.IsApproved)
                {
                    <form method="post" hx-post="@($"/Admin/Users?handler=Approve&id={u.Id}")"
                          hx-target="#users-list" hx-swap="innerHTML">
                        @Html.AntiForgeryToken()
                        <button class="linklike" type="submit">Approve</button>
                    </form>
                }
                else if (u.Id != me)
                {
                    <form method="post" hx-post="@($"/Admin/Users?handler=Revoke&id={u.Id}")"
                          hx-target="#users-list" hx-swap="innerHTML">
                        @Html.AntiForgeryToken()
                        <button class="linklike linklike--danger" type="submit">Revoke</button>
                    </form>
                }
            </div>
        </li>
    }
</ul>
