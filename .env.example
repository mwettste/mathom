# Copy to .env and fill in. The .env file is gitignored.
# cp .env.example .env

# --- Postgres (used by both the db container and the app's connection string) ---
# For local dev with `just db` + running the app from your IDE/CLI, keep these matching the
# default connection string in appsettings.json (mathom/mathom/mathom) so no override is needed.
POSTGRES_USER=mathom
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=mathom

# Host port Postgres is published on (localhost only) for `just db`. The container always
# listens on 5432 internally; the `web` container ignores this and connects over the network.
POSTGRES_PORT=5432

# Connection string used when running the app directly (`just run` / IDE), pointing at the
# `just db` container on localhost. The Docker `web` service overrides this with Host=db, so
# this line only affects non-Docker runs. Keep the credentials in sync with POSTGRES_* above.
ConnectionStrings__Mathom=Host=localhost;Port=5432;Database=mathom;Username=mathom;Password=change-me-please

# Host port to expose the web app on (the container always listens on 8080 internally).
WEB_PORT=8080

# --- Admin ---
# The owner's login email. The user who registers with this email (or an existing user
# with it, on startup) is granted the Admin role + approved, and can approve other users
# at /Admin/Users. Leave blank and no one can approve users — set it before first deploy.
AdminEmail=

# --- LLM providers ---
# OpenRouter alone is enough to test: Infomaniak is the primary provider, but with an
# empty model it fails fast and the client falls back to OpenRouter.
# ASP.NET Core reads nested config from env vars using "__" as the separator.
Llm__OpenRouter__ApiKey=
Llm__OpenRouter__Model=openai/gpt-4o-mini

# Optional: Infomaniak as the primary provider. Leave blank to use OpenRouter only.
# Infomaniak uses its v2 OpenAI endpoint with a json_schema response format (handled in code).
# BaseUrl needs your product-id, the /openai/v1/ segment, and a trailing slash.
# Valid chat models for the OpenAI endpoint: mistral24b, mistral3, qwen3.
# Find your product-id via: curl -H "Authorization: Bearer <key>" https://api.infomaniak.com/1/ai
# Llm__Infomaniak__ApiKey=
# Llm__Infomaniak__Model=mistral24b
# Llm__Infomaniak__BaseUrl=https://api.infomaniak.com/2/ai/<product-id>/openai/v1/

# --- Speech-to-text (voice capture) ---
# Infomaniak Whisper transcription. Set the API key + model to enable voice.
# Transcription is asynchronous (POST returns a batch id; the app polls the results endpoint).
# BaseUrl needs your product-id, the /openai/ segment, and a trailing slash. Find your product-id
# via: curl -H "Authorization: Bearer <key>" https://api.infomaniak.com/1/ai
Stt__Infomaniak__ApiKey=
Stt__Infomaniak__Model=whisper
# Stt__Infomaniak__BaseUrl=https://api.infomaniak.com/1/ai/<product-id>/openai/
